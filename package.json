{
  "name": "cvmaker",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:api",
    "dev:web": "npm run dev --workspace web",
    "dev:api": "npm run dev --workspace api",
    "build": "npm run build --workspace api && npm run build --workspace web",
    "lint": "npm run lint --workspace web",
    "start": "npm run start --workspace api"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
